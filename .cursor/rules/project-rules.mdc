## Architecture Patterns

### Context-based page architecture

1. **Page component** — wraps `Provider` and `ProtectedRoute`
2. **Page container** — consumes context, renders UI
3. **Context provider** — orchestrates hooks only, no business logic
4. **API hooks** (`context/hooks/api/`) — RTK Query + fetch-related `useEffect`
5. **Handler hooks** (`useFeaturePageHandlers`) — mutations, navigation, no `useEffect`
6. **Effect hooks** (`useFeaturePageEffects`) — non-fetch `useEffect` only

### Page component

```typescript
// web/src/pages/FeatureNamePage/FeatureNamePage.tsx
import { ProtectedRoute } from '../../utils/ProtectedRoute';
import { FeatureNamePageProvider } from './context/FeatureNamePageProvider';
import { FeatureNamePageContainer } from './FeatureNamePageContainer';

export const FeatureNamePage = () => (
  <ProtectedRoute>
    <FeatureNamePageProvider>
      <FeatureNamePageContainer />
    </FeatureNamePageProvider>
  </ProtectedRoute>
);
```

### Clean context provider

```typescript
// context/FeatureNamePageProvider.tsx
export const FeatureNamePageProvider = ({ children }: { children: React.ReactNode }) => {
  const featureApi = useFetchFeatureNameData();
  const handlers = useFeatureNamePageHandlers();

  useFeatureNamePageEffects({ data: featureApi.data, handlers });

  const contextValue: IFeatureNamePageContext = { featureApi, handlers };

  return (
    <FeatureNamePageContext.Provider value={contextValue}>
      {children}
    </FeatureNamePageContext.Provider>
  );
};
```

**Do not** put `useState`, `useSelector`, or `useEffect` directly in providers. Keep them in specialized hooks.

### API hook

```typescript
// context/hooks/api/useFetchFeaturePageData.ts
import { useEffect } from 'react';
import { useLocation } from 'react-router-dom';
import { useAppSelector } from '../../../../store';
import { selectFilters } from '../../../../store/slices/featureNamePageSlice';
import { useGetDocumentsQuery } from '../../../../store/api/Documents/documentsApi';

export const useFetchFeaturePageData = () => {
  const location = useLocation();
  const filters = useAppSelector(selectFilters);

  const queryResult = useGetDocumentsQuery(filters);

  useEffect(() => {
    queryResult.refetch();
  }, [location.pathname]);

  return queryResult;
};
```

### Handler hook

```typescript
// context/hooks/useFeaturePageHandlers.ts
import { useCallback } from 'react';
import { useNavigate } from 'react-router-dom';
import { useAppDispatch } from '../../../store';
import { useCreateDocumentMutation } from '../../../store/api/Documents/documentsApi';

export const useFeaturePageHandlers = () => {
  const navigate = useNavigate();
  const dispatch = useAppDispatch();
  const [createDocument, { isLoading: isCreating }] = useCreateDocumentMutation();

  const handleCreate = useCallback(async (data: Partial<IDocumentApi>) => {
    try {
      const result = await createDocument(data).unwrap();
      navigate(`/documents/${result.id}`);
      return { success: true };
    } catch (error) {
      return { success: false };
    }
  }, [createDocument, navigate]);

  return { handleCreate, isCreating };
};
```

### Container component

```typescript
export const FeatureNamePageContainer = () => {
  const { featureApi, handlers } = useFeatureNamePageContext();

  if (featureApi.isLoading) {
    return (
      <div className="flex justify-center items-center p-8">
        <div className="animate-spin h-8 w-8 border-4 border-primary border-t-transparent rounded-full" />
      </div>
    );
  }

  if (featureApi.error) {
    return (
      <Card className="m-4 border-destructive">
        <CardContent className="p-4">
          <p className="text-destructive">Error loading data</p>
        </CardContent>
      </Card>
    );
  }

  return (
    <div className="min-h-screen bg-background">
      <header className="sticky top-0 bg-background border-b p-4">
        <h1 className="text-xl font-semibold">Feature Name</h1>
      </header>
      <main className="max-w-4xl mx-auto p-6 space-y-4">
        {/* content */}
      </main>
    </div>
  );
};
```

