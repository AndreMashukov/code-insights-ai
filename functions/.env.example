# Firebase Functions Environment Variables for Local Development
# Copy this file to functions/.env.local for local development

# Google Generative AI (Gemini) API Key
# Get this from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Project Configuration (automatically set by emulator)
FIREBASE_PROJECT_ID=code-insights-ai

# Storage bucket - must match inject-perfect-document.ts for E2E tests.
# Use .appspot.com for emulator (Storage emulator treats .appspot.com and .firebasestorage.app as different buckets).
STORAGE_BUCKET=code-insights-quiz-ai.appspot.com

# Development Environment
NODE_ENV=development

# Enable debug logging
DEBUG=true